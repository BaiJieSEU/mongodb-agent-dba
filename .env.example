# MongoDB DBA Agent — environment variable configuration
# Copy to .env and fill in values. Never commit .env to git.
#
# All AGENT_* vars override the corresponding agent_config.yaml value.
# Only set the vars relevant to your deployment.

# ── MongoDB ────────────────────────────────────────────────────────────────────
# AGENT_MONGO_CLUSTER=mongodb://your-monitored-cluster:27017
# AGENT_MONGO_STORE=mongodb://your-agent-store:27017

# ── LLM provider ───────────────────────────────────────────────────────────────
# Choose one: ollama | anthropic | azure_openai | bedrock
# AGENT_LLM_PROVIDER=ollama

# ── Ollama (default — data stays on-premises) ──────────────────────────────────
# AGENT_OLLAMA_URL=http://localhost:11434
# AGENT_OLLAMA_MODEL=qwen3:8b

# ── Anthropic API ──────────────────────────────────────────────────────────────
# AGENT_ANTHROPIC_API_KEY=sk-ant-...

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
# AGENT_AZURE_OPENAI_KEY=...
# AGENT_AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com/
# AGENT_AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── AWS Bedrock ────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ── Agent tuning ───────────────────────────────────────────────────────────────
# AGENT_SLOW_QUERY_MS=100
