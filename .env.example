# MongoDB DBA Agent — environment configuration
# Copy to .env and fill in your values.  Never commit .env to git.
#
# All AGENT_* vars override the corresponding config/agent_config.yaml value.
# AGENT_MONGO_STORE is managed by docker-compose.yml — do not set it here.

# ── Monitored MongoDB cluster (required) ────────────────────────────────────
# Connection string of the MongoDB cluster you want to analyse.
#
AGENT_MONGO_CLUSTER=mongodb+srv://user:pass@your-cluster.mongodb.net/

# ── LLM provider ────────────────────────────────────────────────────────────
# Pick ONE block below and uncomment it.

# -- Option A: Anthropic API (cloud, recommended for PS engagements) ---------
AGENT_LLM_PROVIDER=anthropic
# AGENT_ANTHROPIC_API_KEY=sk-ant-...

# -- Option B: Azure OpenAI --------------------------------------------------
# AGENT_LLM_PROVIDER=azure_openai
# AGENT_AZURE_OPENAI_KEY=...
# AGENT_AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com/
# AGENT_AZURE_OPENAI_DEPLOYMENT=gpt-4o

# -- Option C: AWS Bedrock ---------------------------------------------------
# AGENT_LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# -- Option D: Ollama (local, data sovereignty) ------------------------------
# Requires: docker compose --profile ollama up
# Then pull the model: docker exec -it ollama ollama pull qwen3:8b
# AGENT_LLM_PROVIDER=ollama
# AGENT_OLLAMA_MODEL=qwen3:8b
# AGENT_OLLAMA_URL is set automatically to http://ollama:11434 in docker-compose.yml

# ── Agent tuning (optional) ─────────────────────────────────────────────────
# AGENT_SLOW_QUERY_MS=100    # ms threshold for slow query detection (default: 5)
